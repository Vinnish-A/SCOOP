# Python/runtime caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Local environments
.venv*/
venv/
env/

# SCOOP run outputs and temporary benchmark material
tmp/
.scoop_local/
data/
runs/
runs/*/artifacts/
runs/*/logs/
runs/*/reports/
runs/*/*/tables/
runs/*/*/figures/
runs/*/07_de/pseudobulk/
runs/*/07_de/contrasts/
!runs/template/
!runs/template/**/.gitkeep
!runs/template/**/README.md
!runs/template/config/run.yaml

# Large or private omics data artifacts
*.h5ad
*.h5
*.h5seurat
*.loom
*.qs
*.rds
*.rda
*.mtx
*.mtx.gz
*.npz
*.npy
*.parquet
*.feather
*.zarr/
*.zip
*.tar
*.tar.gz
*.tgz

# Retired root-level data/script locations.
/h5ad/
/spatialdata/
/r/

# Local/private configuration overrides
configs/local*.yaml
configs/private*.yaml
project.local.yaml
*.secret.yaml
*.private.yaml
.env
.env.*
